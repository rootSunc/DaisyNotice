PILKE_BASE_URL=https://pilke.daisyfamily.fi/login

# Optional: fill this in after you know the exact inbox URL.
MESSAGES_URL=

# Telegram bot configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WeChat Webhook URL
WECHAT_WEBHOOK_URL=

POLL_INTERVAL_HOURS=
INITIAL_SYNC_MODE=mark-seen

# Optional selector overrides if the default heuristics cannot find messages.
MESSAGE_ROW_SELECTOR=
MESSAGE_TITLE_SELECTOR=
MESSAGE_BODY_SELECTOR=
MESSAGE_DATE_SELECTOR=

# Optional: comma-separated labels used to find the inbox navigation.
MESSAGES_NAV_LABELS=
# Optional debugging.
DEBUG_CAPTURE=0

# Notify channels for sending messages, supports telegram, wechat, and both (default)
NOTIFICATION_CHANNELS=